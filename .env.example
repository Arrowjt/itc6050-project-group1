# PostgreSQL connection
# Copy this file to .env and replace the password
POSTGRES_DB=air_quality
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_this_password

# Host: use 'localhost' when running scripts from your machine
POSTGRES_HOST=localhost
POSTGRES_PORT=5433

# Inside-Docker host (used by the pipeline/dbt/dashboard containers)
POSTGRES_HOST_DOCKER=postgres
POSTGRES_PORT_DOCKER=5432

# OpenAQ v3 API key (required)
# Register at https://explore.openaq.org/register
OPENAQ_API_KEY=your_openaq_api_key_here

# REST Countries v5 API key (required)
# Register at https://restcountries.com/sign-up (free tier: 500 requests/month)
RESTCOUNTRIES_API_KEY=your_restcountries_api_key_here
