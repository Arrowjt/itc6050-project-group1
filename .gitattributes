# Force LF line endings for all text files
* text=auto eol=lf

# Explicitly LF for these
*.py text eol=lf
*.sql text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.md text eol=lf
*.sh text eol=lf
*.env text eol=lf
Dockerfile text eol=lf

# Binary files (don't touch)
*.pdf binary
*.png binary
*.jpg binary
*.jpeg binary
*.gz binary
*.zip binary
